# Whitelist approach: ignore everything by default
*

# Keep root configuration and documentation
!.gitignore
!README.md
.agents/**

# Keep Xiaohongshu Operator files
!xiaohongshu-operator/
!xiaohongshu-operator/**
# Ignore temporary and dependency files in Xiaohongshu Operator
xiaohongshu-operator/temp/
xiaohongshu-operator/node_modules/

# Keep X.com Operator (x-operator) files
!x-operator/
!x-operator/**
# Ignore temporary and noise files in X.com Operator
x-operator/temp/
x-operator/node_modules/
x-operator/-p/
x-operator/mkdir/

# Keep other active projects
!article-image/
!article-image/**
!development/
!development/**
!design/
!design/**
!llm-price-scraper/
!llm-price-scraper/**
llm-price-scraper/prices
llm-price-scraper/prices.csv
llm-price-scraper/prices.json
!akshare-data/
!akshare-data/**
!agent-reach/
!agent-reach/**
!markitdown/
!markitdown/**
markitdown/venv
!markdown-proxy/
!markdown-proxy/**
markdown-proxy/output

!web-search/
!web-search/**
web-search/output

# Global ignore patterns
.DS_Store
Thumbs.db
*.log
